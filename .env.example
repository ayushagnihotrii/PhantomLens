# ── Storage ──────────────────────────────────────────────
# "local"  → saves in ./uploads
# "drive"  → uploads to Google Drive (needs credentials below)
STORAGE_MODE=local

# ── Server ───────────────────────────────────────────────
PORT=3000

# ── Google Drive (only needed when STORAGE_MODE=drive) ───
# Path to your service-account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials.json
# ID of the Drive folder where photos are saved
GOOGLE_DRIVE_FOLDER_ID=
